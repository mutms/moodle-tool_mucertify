{{!
    @template tool_mucertify/catalogue/cetification

    Template to display tenant login URL with copy to clipboard button.

    Context variables required for this template:
    * url - cetification URL
    + fullname - cetification full bame
    * description - cetification description
    * tags - div with cetification tags
    * image - cetification image tag
    * sourceinfo - cetification status and source info

    Example context (json):
    {
        "url": "https://example.com/admin/tool/mucertify/catalogue/cetification.php?id=5",
        "fullname": "Cetification 001",
        "description": "Some cetification",
        "tags": "",
        "image": "",
        "sourceinfo": ""
    }
}}
<div class="card mb-3">
    <div class="row">
        <div class="col-md-8">
            <div class="card-body">
                <h2 class="card-title"><a href="{{url}}">{{fullname}}</a></h2>
                <div class="card-text">{{{description}}}</div>
                {{{tags}}}
            </div>
        </div>
        <div class="col-md-auto">
            {{{image}}}
        </div>
    </div>
    <div class="card-footer text-muted">{{{sourceinfo}}}</div>
</div>
